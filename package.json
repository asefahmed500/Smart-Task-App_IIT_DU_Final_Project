{
  "name": "smart-task",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run db:check && concurrently \"npm run socket:dev\" \"next dev\"",
    "socket:dev": "npx tsx src/socket/server.ts",
    "build": "next build",
    "start": "next start",
    "db:check": "npx tsx scripts/db-check.ts",
    "db:setup": "prisma db push && prisma generate && npm run seed",
    "check-users": "npx tsx -r dotenv/config scripts/check-users.ts dotenv_config_path=.env.local",
    "check-boards": "npx tsx -r dotenv/config scripts/check-member-boards.ts dotenv_config_path=.env.local",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "seed": "npx tsx -r dotenv/config prisma/seed.ts dotenv_config_path=.env.local"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
